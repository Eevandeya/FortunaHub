{
    "name": "fortuna_react",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "preview": "vite preview",
        "lint:fix": "eslint src utils api --fix",
        "prepare": "lefthook install",
        "precommit": "lint-staged",
        "lint": "eslint src utils api --ext js,jsx,ts,tsx, --report-unused-disable-directives --max-warnings 0",
        "format": "prettier --write \"{utils,src,api}/**/*.{js,jsx,css}\"",
        "check": "prettier --check src utils api"
    },
    "dependencies": {
        "@reduxjs/toolkit": "^2.9.1",
        "axios": "^1.11.0",
        "date-fns": "^4.1.0",
        "eslint-config-prettier": "^10.1.1",
        "eslint-plugin-prettier": "^5.2.3",
        "normalize.css": "^8.0.1",
        "prettier": "^3.5.3",
        "react": "^19.0.0",
        "react-datepicker": "^8.7.0",
        "react-dom": "^19.0.0",
        "react-error-boundary": "^6.0.0",
        "react-hook-form": "^7.62.0",
        "react-redux": "^9.2.0",
        "react-router-dom": "^7.9.4",
        "redux-remember": "^5.3.0"
    },
    "devDependencies": {
        "@eslint/js": "^9.21.0",
        "@types/react": "^19.0.10",
        "@types/react-dom": "^19.0.4",
        "@vitejs/plugin-react-swc": "^3.8.0",
        "eslint": "^9.22.0",
        "eslint-plugin-react-hooks": "^5.1.0",
        "eslint-plugin-react-refresh": "^0.4.19",
        "globals": "^15.15.0",
        "lefthook": "^1.13.6",
        "lint-staged": "^16.2.3",
        "pretty-quick": "^4.2.2",
        "vite": "^6.2.0"
    }
}
